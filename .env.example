# Host port mappings for the Docker Compose stack (docker-compose.yml).
# Defaults are deliberately non-standard so the stack runs ALONGSIDE any local
# `npm run dev` / local mongod / local redis without colliding. Copy to .env and
# edit to taste — or just rely on the defaults baked into docker-compose.yml.
#
# Container-internal ports are fixed (services talk via service names:
# mongo:27017, redis:6379, backend:4000, postgres:5432, white-label:4000);
# these only change the HOST side.

FRONTEND_PORT=5274   # browse the app at http://localhost:5274
BACKEND_PORT=4100    # API + Socket.IO at http://localhost:4100
MONGO_PORT=27117     # connect Compass/mongosh to localhost:27117
REDIS_PORT=6479      # connect redis-cli to localhost:6479
WHITELABEL_PORT=4200 # white-label API + lobby at http://localhost:4200
PG_PORT=5532         # connect psql to localhost:5532 (user/pass/db: whitelabel)

# Shared secret pair: the platform signs wallet calls, the white-label verifies.
# Both services MUST see identical values.
OPERATOR_API_KEY=dev-operator-key
OPERATOR_SECRET=dev-operator-secret-change-me
LOBBY_JWT_SECRET=dev-lobby-secret-change-me
