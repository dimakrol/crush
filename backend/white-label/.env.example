NODE_ENV=development
PORT=4000

# Postgres connection. For local (non-Docker) dev point at the host-published
# port from the root docker-compose (default 5532). Inside Compose this is
# overridden to postgres:5432.
DATABASE_URL=postgresql://whitelabel:whitelabel@localhost:5532/whitelabel

# Lobby player session (the casino's own login).
LOBBY_JWT_SECRET=dev-lobby-secret-change-me
LOBBY_JWT_EXPIRES_IN=1h

# Server-to-server wallet API auth (platform <-> white-label, HMAC).
# These MUST match the platform's OPERATOR_API_KEY / OPERATOR_SECRET.
OPERATOR_API_KEY=dev-operator-key
OPERATOR_SECRET=dev-operator-secret-change-me

# Game launch + iframe.
GAME_FRONTEND_URL=http://localhost:5274
GAME_ID=crash-pilot
LAUNCH_TOKEN_TTL_SECONDS=60

# Seed balance in integer minor units (100000 = 1000.00 USD).
INITIAL_DEMO_BALANCE=100000

CORS_ORIGIN=http://localhost:5274
