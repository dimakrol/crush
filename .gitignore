# Node artifact files
node_modules/
dist/
.pnpm-store/
!scripts/entrypoint.sh
!scripts/prisma-auto-baseline.mjs
# Compiled Java class files
# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Maven
target/

# JetBrains IDE
.idea/

.cursorrules
.cursorignore
.vscode

# Unit test reports
TEST*.xml

# Curl integration test output (scripts/agents-curl-integration-test.sh)
reports/

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# Environment variables
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
.env.stage

# Prisma
/generated
/generated/prisma
/generated/prisma-platform
/generated/prisma-automations
/generated/prisma-contacts
/generated/prisma-conversations
prisma/migrations
*.db
*.db-journal
service-account.json

/plans

# Local PostgreSQL dumps (created from jobix-postgres; may contain sensitive data)
pg-dumps/
